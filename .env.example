# ⚙️ Environment Variables Template
# Copy this file to .env and fill in your values
# NOTE: Spring Boot reads from application.properties by default
# Set these as system environment variables or in application-*.properties

# ===========================================
# 🗄️ DATABASE CONFIGURATION
# ===========================================

# Local Development (MySQL 8.0)
DB_URL=jdbc:mysql://localhost:3306/lms_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# Docker (when running docker-compose.simple.yml)
# DB_URL=jdbc:mysql://mysql:3306/lms_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USERNAME=lms_user
# DB_PASSWORD=lms_password

# Production (Render/Railway)
# DB_URL=jdbc:mysql://dpg-xxxxx.singapore-postgres.render.com:5432/lms_db
# DB_USERNAME=lms_user
# DB_PASSWORD=<your-production-password>

# ===========================================
# 🔐 SECURITY CONFIGURATION
# ===========================================

# JWT Secret Key (MUST be 32+ bytes for HS256)
# Generate: openssl rand -base64 32
# Or: PowerShell: -join ((48..57)+(65..90)+(97..122)|Get-Random -Count 32|%{[char]$_})
APP_JWT_SECRET=change-me-to-a-random-32-byte-secret-key

# JWT Expiration (milliseconds) - Default: 86400000 (24 hours)
# APP_JWT_EXPIRATION=86400000

# ===========================================
# 🔴 REDIS CONFIGURATION
# ===========================================

# Local Development
REDIS_HOST=localhost
REDIS_PORT=6379

# Docker
# REDIS_HOST=redis
# REDIS_PORT=6379

# Production (Render/Railway)
# REDIS_HOST=red-xxxxx.singapore-redis.render.com
# REDIS_PORT=6379
# REDIS_PASSWORD=<if-required>

# ===========================================
# 🤖 GEMINI AI CHATBOT (Optional)
# ===========================================

# Get API key: https://makersuite.google.com/app/apikey
# Leave empty to disable chatbot feature
GEMINI_API_KEY=

# Gemini Model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Rate Limiting
# chat.rate.window-millis=60000
# chat.rate.max-requests=10
# chat.rate.backend=auto

# ===========================================
# 📧 EMAIL CONFIGURATION (Optional)
# ===========================================

# Required for "Forgot Password" feature
# Gmail: Use App Password (https://myaccount.google.com/apppasswords)

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Email From Address
# MAIL_FROM=noreply@library.com

# ===========================================
# 🚀 APPLICATION CONFIGURATION
# ===========================================

# Spring Profile (dev | prod | test)
SPRING_PROFILES_ACTIVE=dev

# Server Port (default: 8080)
# SERVER_PORT=8080

# ===========================================
# 🐳 DOCKER/PRODUCTION SPECIFIC
# ===========================================

# JVM Memory Settings
# JAVA_OPTS=-Xms256m -Xmx512m -XX:MaxRAMPercentage=75.0 -XX:+UseG1GC

# ===========================================
# 📊 LOGGING (Optional)
# ===========================================

# Log Level (TRACE | DEBUG | INFO | WARN | ERROR)
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_IBIZABROKER_LMS=DEBUG

# ===========================================
# 🌐 CORS (Production)
# ===========================================

# Allowed Origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# ===========================================
# 📝 NOTES
# ===========================================

# 1. NEVER commit .env to Git! (Already in .gitignore)
# 2. For production: Use platform's environment variables
# 3. Minimum required: DB_*, APP_JWT_SECRET
# 4. Optional: GEMINI_API_KEY (chatbot), MAIL_* (password reset)

# ===========================================
# 🔗 USEFUL LINKS
# ===========================================

# - Gemini API: https://makersuite.google.com/app/apikey
# - Gmail App Password: https://myaccount.google.com/apppasswords
# - Random Key Generator: https://randomkeygen.com/
